<Window x:Class="BimManagement.CreateReportSheetView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSL – Crear Reporte de Hojas"
        Width="660" Height="750"
        MinWidth="560" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5">

    <Window.Resources>

        <!-- ── Brushes ─────────────────────────────────── -->
        <SolidColorBrush x:Key="HeaderBg"       Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBlue"     Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHover"    Color="#1D4ED8"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary"  Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderColor"    Color="#E5E7EB"/>
        <SolidColorBrush x:Key="InputBorder"    Color="#D1D5DB"/>

        <!-- ── Card ─────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#E5E7EB"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="18"/>
            <Setter Property="Margin"           Value="0,0,0,12"/>
        </Style>

        <!-- ── Section title ────────────────────────────── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin"     Value="0,0,0,12"/>
        </Style>

        <!-- ── Field label ──────────────────────────────── -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- ── Input ────────────────────────────────────── -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height"                  Value="36"/>
            <Setter Property="Padding"                 Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"             Value="#D1D5DB"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Background"              Value="White"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Foreground"              Value="#111827"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Tab RadioButton ──────────────────────────── -->
        <Style x:Key="TabRadio" TargetType="RadioButton">
            <Setter Property="Foreground"       Value="#6B7280"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="18,0"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground"  Value="#2563EB"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary button ───────────────────────────── -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="22,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Secondary button ─────────────────────────── -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger button ─────────────────────────────── -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#DC2626"/>
            <Setter Property="BorderBrush"     Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEF2F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- ═══════════════════ HEADER ═══════════════════ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" Padding="22,16">
            <StackPanel>
                <TextBlock Text="CSL – Crear Reporte de Hojas"
                           FontSize="17" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Configure los parámetros para generar el reporte en los modelos"
                           FontSize="12" Foreground="#93C5FD" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ FOOTER ═══════════════════ -->
        <Border DockPanel.Dock="Bottom" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                    <ProgressBar Name="ProgressBar" Height="5"
                                 Minimum="0" Value="0"
                                 Foreground="#2563EB" Background="#E5E7EB"/>
                    <TextBlock Name="ProgressLabel" Text="" FontSize="11"
                               Foreground="#6B7280" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Name="FindFilesBtn"
                        Grid.Column="1" Content="Buscar archivos"
                        Style="{StaticResource BtnSecondary}"
                        Width="130" Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="FindFiles_Click"/>

                <Button Grid.Column="2" Content="Ejecutar"
                        Style="{StaticResource BtnPrimary}"
                        Width="100" Margin="0,0,8,0"
                        Click="Execute_Click"/>

                <Button Grid.Column="3" Content="Cancelar"
                        Style="{StaticResource BtnDanger}"
                        Width="90"
                        Click="Cancel_Click"/>
            </Grid>
        </Border>

        <!-- ═══════════════════ CONTENT ══════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,16,16,4">
            <StackPanel>

                <!-- ── Tipo de reporte ─────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="TIPO DE REPORTE" Style="{StaticResource SectionTitle}"/>
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB"
                                BorderThickness="1" CornerRadius="6" Padding="4">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Name="SemanalRadio" Content="Semanal"
                                             Style="{StaticResource TabRadio}"
                                             IsChecked="True"
                                             Checked="ReportType_Changed"/>
                                <RadioButton Name="MensualRadio" Content="Mensual"
                                             Style="{StaticResource TabRadio}"
                                             Checked="ReportType_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Datos del reporte ──────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DATOS DEL REPORTE" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Semana (solo semanal) -->
                            <StackPanel Name="WeekPanel" Grid.Column="0">
                                <TextBlock Text="Semana N°" Style="{StaticResource Label}"/>
                                <TextBox Name="IssueWeek" Style="{StaticResource Input}"
                                         TextChanged="IssueWeek_TextChanged"
                                         ToolTip="Número de semana del reporte"/>
                            </StackPanel>

                            <!-- Mes (solo mensual) -->
                            <StackPanel Name="MonthPanel" Grid.Column="0" Visibility="Collapsed">
                                <TextBlock Text="Mes" Style="{StaticResource Label}"/>
                                <TextBox Name="MonthBox" Style="{StaticResource Input}"
                                         ToolTip="Formato: MM/yyyy  (ej: 03/2025)"/>
                            </StackPanel>

                            <!-- Período (siempre visible) -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Período" Style="{StaticResource Label}"/>
                                <TextBox Name="PeriodoBox" Style="{StaticResource Input}"
                                         ToolTip="Período del reporte  (ej: 01/03 - 07/03)"/>
                            </StackPanel>
                        </Grid>

                        <!-- Fecha de presentación -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fecha de Presentación" Style="{StaticResource Label}"/>
                                <TextBox Name="FechaPresentacionBox" Style="{StaticResource Input}"
                                         ToolTip="Fecha de presentación del reporte (dd/MM/yyyy)"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Alcance ────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ALCANCE" Style="{StaticResource SectionTitle}"/>

                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB"
                                BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Name="CurrentModelRadio" Content="Modelo actual"
                                             Style="{StaticResource TabRadio}"
                                             IsChecked="True"
                                             Checked="Scope_Changed"/>
                                <RadioButton Name="FolderRadio" Content="Carpeta de modelos"
                                             Style="{StaticResource TabRadio}"
                                             Checked="Scope_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Info modelo actual -->
                        <Border Name="CurrentModelInfo"
                                Background="#F0FDF4" BorderBrush="#86EFAC"
                                BorderThickness="1" CornerRadius="6" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="#16A34A"
                                           FontWeight="Bold" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Se aplicará al modelo actualmente abierto en Revit."
                                           Foreground="#166534" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Panel carpeta -->
                        <StackPanel Name="FolderPanel" Visibility="Collapsed">
                            <TextBlock Text="Ruta de la carpeta" Style="{StaticResource Label}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Name="FolderPathBox" Grid.Column="0"
                                         Style="{StaticResource Input}"/>
                                <Button Grid.Column="2" Content="Examinar…"
                                        Style="{StaticResource BtnSecondary}"
                                        Width="90" Click="SelectFolder_Click"/>
                            </Grid>

                            <CheckBox Name="IncludeSubfoldersCheck"
                                      Content="Incluir subcarpetas"
                                      IsChecked="True"
                                      Foreground="#374151" FontSize="13"
                                      Margin="2,0,0,12"/>

                            <!-- Lista de archivos -->
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                                <StackPanel>
                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB"
                                            BorderThickness="0,0,0,1" Padding="12,8"
                                            CornerRadius="6,6,0,0">
                                        <TextBlock Name="FilesCountLabel"
                                                   Text="Archivos encontrados"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#6B7280"/>
                                    </Border>
                                    <ListView Name="RvtFilesList" BorderThickness="0"
                                              MaxHeight="160" Background="White">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Archivo"
                                                                DisplayMemberBinding="{Binding Name}"
                                                                Width="220"/>
                                                <GridViewColumn Header="Ruta"
                                                                DisplayMemberBinding="{Binding DirectoryName}"
                                                                Width="340"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Log ───────────────────────────────── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="LOG" Style="{StaticResource SectionTitle}"/>
                        <TextBox Name="LogTextBox" Height="80"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#0F172A" Foreground="#6EE7B7"
                                 BorderThickness="0" Padding="10"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
