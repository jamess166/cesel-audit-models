<Window x:Class="BimManagement.ShareSheetsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSL – Exportar Planos PDF"
        Width="640" Height="700"
        MinWidth="500" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F2F5">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBg"   Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="16"/>
            <Setter Property="Margin"          Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="#D1D5DB"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="FontSize"                 Value="12"/>
        </Style>

        <Style x:Key="TabRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="18,0"/>
            <Setter Property="Height"     Value="32"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="22,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#DC2626"/>
            <Setter Property="BorderBrush"     Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEF2F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" Padding="22,16">
            <StackPanel>
                <TextBlock Text="CSL – Exportar Planos PDF"
                           FontSize="17" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Exporta los planos 2235055-CSL a la carpeta ANEXOS del reporte"
                           FontSize="12" Foreground="#93C5FD" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <Border DockPanel.Dock="Bottom" Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="StatusLabel" Grid.Column="0" VerticalAlignment="Center"
                           FontSize="11" Foreground="#6B7280"/>

                <Button Grid.Column="1" Name="ExportBtn" Content="Exportar PDF"
                        Style="{StaticResource BtnPrimary}"
                        Width="130" Margin="0,0,8,0"
                        Click="Export_Click"/>

                <Button Grid.Column="2" Content="Cancelar"
                        Style="{StaticResource BtnDanger}"
                        Width="90" Click="Cancel_Click"/>
            </Grid>
        </Border>

        <!-- CONTENT (sin ScrollViewer, usa Grid con filas flexibles) -->
        <Grid Margin="16,14,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Alcance -->
                <RowDefinition Height="Auto"/>  <!-- Carpeta destino -->
                <RowDefinition Height="Auto"/>  <!-- Panel carpeta modelos -->
                <RowDefinition Height="*"/>     <!-- Lista de planos (expande) -->
            </Grid.RowDefinitions>

            <!-- ── Alcance ── -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="ALCANCE" Style="{StaticResource SectionTitle}"/>
                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Name="CurrentModelRadio" Content="Modelo actual"
                                         Style="{StaticResource TabRadio}"
                                         IsChecked="True" Checked="Scope_Changed"/>
                            <RadioButton Name="FolderRadio" Content="Carpeta de modelos"
                                         Style="{StaticResource TabRadio}"
                                         Checked="Scope_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Carpeta destino ── -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="CARPETA DESTINO" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="OutputPathBox" Grid.Column="0"
                                 Style="{StaticResource Input}"
                                 IsReadOnly="True" Background="#F9FAFB" Foreground="#374151"/>
                        <Button Grid.Column="2" Content="Cambiar"
                                Style="{StaticResource BtnSecondary}"
                                Width="75" Click="ChangeFolder_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Panel carpeta de modelos (solo visible en modo Carpeta) ── -->
            <Border Grid.Row="2" Name="FolderPanel" Style="{StaticResource Card}"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="CARPETA DE MODELOS" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="FolderPathBox" Grid.Column="0"
                                 Style="{StaticResource Input}"/>
                        <Button Grid.Column="2" Content="Examinar…"
                                Style="{StaticResource BtnSecondary}"
                                Width="85" Click="SelectFolder_Click"/>
                        <Button Grid.Column="4" Content="Buscar"
                                Style="{StaticResource BtnSecondary}"
                                Width="70" Click="FindFiles_Click"/>
                    </Grid>
                    <CheckBox Name="IncludeSubfoldersCheck" Content="Incluir subcarpetas"
                              IsChecked="True" FontSize="12" Foreground="#374151" Margin="2,0,0,8"/>
                    <!-- Lista de archivos encontrados -->
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" MaxHeight="110">
                        <ListView Name="RvtFilesList" BorderThickness="0" Background="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Archivo"
                                                    DisplayMemberBinding="{Binding Name}" Width="200"/>
                                    <GridViewColumn Header="Ruta"
                                                    DisplayMemberBinding="{Binding DirectoryName}" Width="300"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                    <TextBlock Name="FilesCountLabel" Text="Archivos encontrados: 0"
                               FontSize="11" Foreground="#6B7280" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Lista de planos (modelo actual) ── -->
            <Border Grid.Row="3" Name="SheetListPanel" Style="{StaticResource Card}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="PLANOS A EXPORTAR" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Seleccionar todos" Style="{StaticResource BtnSecondary}"
                                    Padding="12,0" Height="28" FontSize="12"
                                    Click="SelectAll_Click"/>
                            <Button Content="Deseleccionar todos" Style="{StaticResource BtnSecondary}"
                                    Padding="12,0" Height="28" FontSize="12" Margin="8,0,0,0"
                                    Click="DeselectAll_Click"/>
                            <TextBlock Name="CountLabel" VerticalAlignment="Center"
                                       FontSize="12" Foreground="#6B7280" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <ListBox Name="SheetsList"
                             BorderBrush="#E5E7EB" BorderThickness="1"
                             Background="White" HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Content="{Binding Display}"
                                          FontSize="12" Foreground="#111827" Padding="6,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
